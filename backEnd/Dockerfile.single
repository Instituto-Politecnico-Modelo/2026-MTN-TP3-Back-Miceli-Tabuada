# Single-stage Dockerfile — útil para debug local (no para producción)
FROM eclipse-temurin:17-jdk-alpine

RUN addgroup -S app && adduser -S app -G app

WORKDIR /app
COPY mvnw mvnw.cmd ./
COPY .mvn/ .mvn/
COPY pom.xml .
COPY src/ src/

RUN chmod +x mvnw && chown -R app:app /app

USER app
EXPOSE 8081
CMD ["./mvnw", "spring-boot:run"]

