# Single-stage Dockerfile with full JDK
FROM eclipse-temurin:21-jdk-alpine
WORKDIR /app
COPY pom.xml .
COPY src/ src/
COPY mvnw .
COPY mvnw.cmd .
COPY .mvn/ .mvn/
RUN apk add --no-cache maven && \
    mvn clean package -DskipTests && \
    mv target/backEnd-*.jar app.jar
EXPOSE 8081
ENTRYPOINT ["java", "-jar", "app.jar"]

